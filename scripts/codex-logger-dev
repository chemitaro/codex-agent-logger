#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if ! command -v uv >/dev/null 2>&1; then
  echo "error: uv is not installed (required for local dev runner)" >&2
  exit 127
fi

exec uv run --project "${REPO_ROOT}" --frozen python -m codex_logger.cli "$@"

