#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: $(basename "$0") \"<title>\"" >&2
}

if [[ "$#" -ne 1 ]]; then
  usage
  exit 2
fi

title="$1"
script_dir="$(cd "$(dirname "$0")" >/dev/null 2>&1 && pwd -P)"

find_runtime() {
  local start_dir="$1"
  local dir="$start_dir"
  local depth=0
  while true; do
    local candidate="$dir/spec-dock/scripts/spec-dock"
    if [[ -f "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
    if [[ "$dir" == "/" ]] || (( depth >= 50 )); then
      return 1
    fi
    dir="$(dirname "$dir")"
    depth=$((depth + 1))
  done
}

if ! runtime_script="$(find_runtime "$script_dir")"; then
  echo "new-adr: runtime script not found: spec-dock/scripts/spec-dock" >&2
  echo "new-adr: search start: $script_dir" >&2
  echo "new-adr: run 'spec-dock init' or 'spec-dock update' and verify 'spec-dock/' is installed." >&2
  exit 1
fi

meta_path="$script_dir/../meta.json"
if [[ ! -f "$meta_path" ]]; then
  echo "new-adr: missing meta.json: $meta_path" >&2
  echo "new-adr: fix ../meta.json and retry." >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "new-adr: python3 is required to parse meta.json." >&2
  exit 1
fi

if ! meta_pair="$(
  python3 - "$meta_path" <<'PY'
import json
import sys

path = sys.argv[1]
try:
    with open(path, encoding="utf-8") as f:
        data = json.load(f)
except Exception as exc:
    print(f"new-adr: invalid meta.json: {path}: {exc}", file=sys.stderr)
    raise SystemExit(1)

node_id = data.get("id")
if not isinstance(node_id, str) or not node_id.strip():
    print(f"new-adr: missing 'id' in {path}", file=sys.stderr)
    raise SystemExit(1)

node_type = data.get("type")
if node_type not in {"initiative", "epic", "issue"}:
    print(f"new-adr: unsupported type in {path}: {node_type!r}", file=sys.stderr)
    raise SystemExit(1)

print(f"{node_type}\t{node_id.strip()}")
PY
)"; then
  echo "new-adr: fix ../meta.json and retry." >&2
  exit 1
fi

scope_type="${meta_pair%%$'\t'*}"
scope_id="${meta_pair#*$'\t'}"
case "$scope_type" in
  initiative)
    scope_flag="--initiative"
    ;;
  epic)
    scope_flag="--epic"
    ;;
  issue)
    scope_flag="--issue"
    ;;
  *)
    echo "new-adr: unsupported type: $scope_type" >&2
    exit 1
    ;;
esac

exec "$runtime_script" new adr "$scope_flag" "$scope_id" --title "$title"
